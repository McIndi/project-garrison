# Garrison environment template for Ansible CLI runs
# Usage:
#   cp .env.example .env
#   set -a; source .env; set +a
# Verify the file was sourced:
#   test "${GARRISON_ENV_SOURCED:-}" = "garrison-env-loaded-v1"

# Sentry value used to verify .env is sourced.
GARRISON_ENV_SOURCED=garrison-env-loaded-v1

# Disable no_log redaction for sensitive tasks when deep troubleshooting is needed.
# WARNING: true will print secrets/tokens to console and logs.
# Default should remain false.
GARRISON_LOG_NOLOG=false

# Project roots for the co-deploy execution model.
# Garrison runs inside armory's VM as a follow-on deployment.
# Set these to YOUR VM's real layout — all other paths derive from them.
# (Observed on the current VM: garrison lives under /opt/garrison.)
GARRISON_PROJECT_ROOT=/opt/garrison/project-garrison
# Only used by the bringup-all convenience wrapper — garrison does NOT import
# armory files (it vendors patterns). Set to your VM's armory checkout, or unset.
ARMORY_PROJECT_ROOT=/opt/garrison/project-armory

# Kubeconfig path from armory's k3s installation.
ARMORY_KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml

# Public domain settings used for OIDC host calculations.
ARMORY_PUBLIC_DOMAIN=armory.local
ARMORY_PUBLIC_BASE_URL=https://armory.local
AGENTSTACK_UI_HOST=agentstack.armory.local

# Extra SAN hostnames appended to Armory's consolidated edge certificate.
# This flows into Armory's deploy path via the shared environment.
ARMORY_EDGE_EXTRA_SAN_HOSTS=api.agentstack.armory.local,agentstack.armory.local

# Ansible root for this repository.
GARRISON_ANSIBLE_ROOT=${GARRISON_PROJECT_ROOT}/ansible

# Core Ansible settings.
ANSIBLE_INVENTORY=inventories/development/hosts.yml
ANSIBLE_ROLES_PATH=roles
ANSIBLE_HOST_KEY_CHECKING=False
ANSIBLE_RETRY_FILES_ENABLED=False
ANSIBLE_PYTHON_INTERPRETER=auto_silent
ANSIBLE_LOG_PATH=${GARRISON_PROJECT_ROOT}/log/ansible.log
ANSIBLE_DISPLAY_ARGS_TO_STDOUT=True
ANSIBLE_LOAD_CALLBACK_PLUGINS=True
ANSIBLE_CALLBACKS_ENABLED=timer
ANSIBLE_BECOME=True
ANSIBLE_BECOME_METHOD=sudo
ANSIBLE_BECOME_ASK_PASS=False

# Useful runtime defaults.
ANSIBLE_STDOUT_CALLBACK=default
ANSIBLE_FORKS=5
ANSIBLE_TIMEOUT=60
ANSIBLE_VERBOSITY=0
ANSIBLE_DEPRECATION_WARNINGS=True
ANSIBLE_SYSTEM_WARNINGS=True
ANSIBLE_INVENTORY_UNPARSED_WARNING=True
ANSIBLE_HOST_PATTERN_MISMATCH=warning
ANSIBLE_GATHERING=implicit
ANSIBLE_PIPELINING=False
ANSIBLE_DIFF_ALWAYS=False
ANSIBLE_DIFF_CONTEXT=3
ANSIBLE_FORCE_COLOR=False
ANSIBLE_NOCOLOR=False
