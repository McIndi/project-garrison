---
# YAML Lint Configuration
# See https://yamllint.readthedocs.io/

extends: default

rules:
  line-length:
    max: 160
    level: warning

  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false

  comments:
    min-spaces-from-content: 1
    require-starting-space: true
  comments-indentation: false

  document-start:
    present: true
  document-end:
    present: false

  trailing-spaces: enable

  empty-lines:
    max: 2
    max-start: 0
    max-end: 1

  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on', 'off']
    check-keys: false

  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  key-duplicates: enable

  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore: |
  .git/
  .github/
  __pycache__/
  .molecule/
  .tox/
  .venv/
