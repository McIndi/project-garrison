---
# Syncs the seed-admin login credentials (OpenBao KV → k8s Secret) so they can be
# retrieved with `kubectl get secret {{ agentstack_admin_creds_secret_name }}`
# instead of decrypting the break-glass root token. Keys: username, password.
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: {{ agentstack_admin_creds_vso_name }}
  namespace: {{ agentstack_namespace }}
spec:
  type: kv-v2
  mount: {{ openbao_kv_mount }}
  path: "{{ agentstack_admin_creds_openbao_path }}"
  destination:
    name: {{ agentstack_admin_creds_secret_name }}
    create: true
  vaultAuthRef: {{ agentstack_vault_auth_name }}
  refreshAfter: {{ agentstack_client_secrets_refresh_after }}
  hmacSecretData: true
