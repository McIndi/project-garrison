---
# COMBINED trust bundle (public default roots + private Armory Root CA) →
# agentstack namespace. Used by agentstack PODS at runtime as their CA bundle.
# It must contain BOTH:
#   1. the public/default CA roots — so the Python server can verify PUBLIC TLS
#      endpoints (github.com during `agentstack add`, model providers, etc.). The
#      server sets SSL_CERT_FILE/REQUESTS_CA_BUNDLE to this file, and for Python
#      those env vars REPLACE the system trust store (unlike Node's additive
#      NODE_EXTRA_CA_CERTS) — so a private-only bundle breaks all public TLS with
#      "unable to get local issuer certificate".
#   2. the private Armory Root CA (CN=Armory Root CA) — so pods can validate the
#      private OIDC issuer (https://<armory-host>/realms/agentstack via
#      nginx-ingress armory-tls). Sourced from openbao-ui-tls's ca.crt in the
#      openbao trust namespace (trust-manager --trust-namespace=openbao).
apiVersion: trust.cert-manager.io/v1alpha1
kind: Bundle
metadata:
  name: {{ agentstack_trust_public_ca_bundle_name }}
spec:
  sources:
    # Public/default CA roots shipped by trust-manager (Mozilla bundle). REQUIRED
    # for the server to verify public endpoints — see header note on Python's
    # replace-the-trust-store semantics. Needs trust-manager's default CA package
    # enabled (defaultPackage.enabled, on by default in the trust-manager chart).
    - useDefaultCAs: true
    - secret:
        name: {{ agentstack_trust_public_ca_source_secret_name }}
        key: {{ agentstack_trust_public_ca_source_key }}
  target:
    secret:
      key: {{ agentstack_trust_public_ca_target_key }}
    namespaceSelector:
      matchExpressions:
        - key: kubernetes.io/metadata.name
          operator: In
          values:
            - {{ agentstack_namespace }}
